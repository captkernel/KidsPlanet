{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/website/layout,_N_T_/website/page,_N_T_/website"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/website/__PAGE__",
    "/website",
    "/_index",
    "/_head"
  ]
}